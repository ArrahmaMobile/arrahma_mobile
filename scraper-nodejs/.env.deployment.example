# SSL/TLS Configuration for GCP Deployment
# Copy this file to .env.deployment and fill in your values
# Then run: source .env.deployment && ./deploy-from-local.sh

# ============================================================
# SSL/TLS Settings (OPTIONAL - Auto-detected from VM)
# ============================================================
# Note: The deployment script automatically detects these from
# your existing VM configuration. You only need to set these if:
#   1. Changing to a different domain
#   2. Using a different email
#   3. Forcing SSL re-setup
#
# Current auto-detected values:
#   Domain: arrahmah.sasid.me (from Nginx config)
#   Email: tehtech1337@gmail.com (from GCP account)
#   External IP: 34.59.136.229

# Your domain name (leave commented to auto-detect: arrahmah.sasid.me)
# export SSL_DOMAIN="arrahmah.sasid.me"

# Your email for Let's Encrypt certificate notifications
# Leave commented to use GCP account email (recommended)
# export SSL_EMAIL="your-email@example.com"

# SSL setup mode: auto | yes | no
# - auto: Setup SSL only if certificate doesn't exist (recommended)
# - yes: Always run SSL setup (useful for reconfiguration)
# - no: Skip SSL setup (HTTP only)
export SETUP_SSL="auto"

# ============================================================
# GCP Configuration (Optional - defaults provided)
# ============================================================

# GCP VM instance name
export GCP_VM_NAME="arrahmah-api"

# GCP zone where VM is located
export GCP_ZONE="us-central1-c"

# GCP project ID
export GCP_PROJECT="arrahmah-islamic-institute"

# GCP account email to use for authentication
export GCP_ACCOUNT="tehtech1337@gmail.com"

# ============================================================
# Deployment Configuration (Optional)
# ============================================================

# Path to repository on the VM
export REPO_PATH="~/arrahmah-scraper/scraper-nodejs"

# Git branch to deploy
export BRANCH="feat/update-api"

# PM2 application name
export PM2_APP_NAME="arrahmah-api"

# ============================================================
# Usage Instructions
# ============================================================
#
# 1. Copy this file:
#    cp .env.deployment.example .env.deployment
#
# 2. Edit .env.deployment with your actual values:
#    nano .env.deployment
#
# 3. Source the environment variables:
#    source .env.deployment
#
# 4. Run deployment:
#    ./deploy-from-local.sh
#
# The script will automatically set up SSL/TLS if configured!
#
# ============================================================

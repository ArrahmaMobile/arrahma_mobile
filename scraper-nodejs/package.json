{
  "name": "arrahmah-scraper",
  "version": "1.0.0",
  "description": "Node.js scraper for Arrahmah Islamic Institute content",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "scrape": "npm run build && npm start",
    "api": "npm run build && node dist/api/server.js",
    "api:dev": "ts-node src/api/server.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "scraper",
    "arrahmah",
    "islamic",
    "web-scraping"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "axios": "^1.16.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-cron": "^4.2.1",
    "p-queue": "^8.0.1",
    "turndown": "^7.1.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/turndown": "^5.0.4",
    "@types/xml2js": "^0.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
